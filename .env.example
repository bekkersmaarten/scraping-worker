# Servicebox credentials
SERVICEBOX_URL=https://servicebox.mpsa.com
SERVICEBOX_USERNAME=your-username
SERVICEBOX_PASSWORD=your-password

# Server config
PORT=3001

# Playwright options (overridden in Dockerfile for production)
HEADLESS=true
SLOW_MO=0

# Callback security (moet overeenkomen met Supabase Edge Function secret)
CALLBACK_SECRET=your-secret-here
